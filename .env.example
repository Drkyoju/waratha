# Public site URL (used for Open Graph metadata and canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact email displayed on the site and used for inbound notifications
CONTACT_EMAIL=contact@waratha.sa

# Resend API key for transactional email (swap in when ready)
RESEND_API_KEY=your_resend_api_key_here

# Verified sender address in Resend (defaults to onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Waratha <onboarding@resend.dev>
